<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#242F3E">

    <TextView
        android:id="@+id/tvPinHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter UPI PIN"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvPinAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Amount: ₹0"
        android:textColor="@color/onboarding_blue"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etUpiPin"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_input_field"
        android:gravity="center"
        android:hint="* * * *"
        android:inputType="numberPassword"
        android:maxLength="6"
        android:paddingHorizontal="16dp"
        android:textColor="@color/white"
        android:textColorHint="#4A5568"
        android:textSize="24sp"
        android:letterSpacing="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitPin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Pay Securely"
        android:textAllCaps="false"
        android:textStyle="bold"
        app:cornerRadius="16dp"
        app:backgroundTint="@color/onboarding_blue" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_gravity="center"
        android:text="Secured by Razorpay"
        android:textColor="#4A5568"
        android:textSize="12sp" />
</LinearLayout>
