<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/onboarding_bg"
    tools:context=".PrivacyPolicyActivity">

    <!-- Top Navigation Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clToolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Privacy &amp; Policy"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TravelBuddy Privacy Guidelines"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.5"
                android:text="Last Updated: May 2026"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <!-- Policy 1 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="1. Information We Collect"
                android:textColor="@color/onboarding_blue"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0.8"
                android:lineSpacingMultiplier="1.2"
                android:text="We collect account credentials (your full name, email, and password) directly to configure and personalize your TravelBuddy experiences. GPS location data is accessed securely in real-time only to provide custom local weather, upcoming trip statuses, and nearby map coordinates."
                android:textColor="@color/white"
                android:textSize="14sp" />

            <!-- Policy 2 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="2. AI Assistant &amp; Chat Data"
                android:textColor="@color/onboarding_blue"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0.8"
                android:lineSpacingMultiplier="1.2"
                android:text="Any conversations or inquiries with our Chat AI companion are handled dynamically on encrypted database records. We analyze user input strictly to curate smart, high-quality answers and recommendations, ensuring your conversations are never shared with advertising entities."
                android:textColor="@color/white"
                android:textSize="14sp" />

            <!-- Policy 3 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="3. Database &amp; Local Protection"
                android:textColor="@color/onboarding_blue"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0.8"
                android:lineSpacingMultiplier="1.2"
                android:text="All user accounts, password updates, and session states are securely registered in our SQL tables on our backend. We utilize advanced validation patterns on emails and passwords to ensure account integrity, keeping your personal credentials completely isolated and private."
                android:textColor="@color/white"
                android:textSize="14sp" />

            <!-- Policy 4 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="4. Razorpay Secure Gateways"
                android:textColor="@color/onboarding_blue"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0.8"
                android:lineSpacingMultiplier="1.2"
                android:text="All payment bookings, tickets, and financial transactions are routed directly via official SDK integrations (e.g. Razorpay). TravelBuddy does not store your credit card or CVV details, maintaining a 100% compliance record with secure payment guidelines."
                android:textColor="@color/white"
                android:textSize="14sp" />

            <!-- Policy 5 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="5. Contact &amp; Compliance"
                android:textColor="@color/onboarding_blue"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0.8"
                android:lineSpacingMultiplier="1.2"
                android:text="TravelBuddy reserves the right to modify these guidelines to align with Google Play and secure framework policies. For any inquiries regarding location usage or data deletion options, please navigate to our Help &amp; Support section."
                android:textColor="@color/white"
                android:textSize="14sp" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
